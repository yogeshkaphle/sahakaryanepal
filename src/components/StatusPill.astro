---
interface Props { status: 'ongoing' | 'completed'; }
const { status } = Astro.props;
const label = status === 'completed' ? 'Completed' : 'Ongoing';
---
<span class:list={['status-pill', status]}><span class="dot" aria-hidden="true"></span>{label}</span>
<style>
  .status-pill { align-items: center; border-radius: 999px; display: inline-flex; font-size: 0.85rem; font-weight: var(--weight-medium); gap: 0.4rem; line-height: 1; padding: 0.45rem 0.65rem; }
  .dot { border-radius: 50%; display: inline-block; height: 0.5rem; width: 0.5rem; }
  .completed { background: color-mix(in srgb, var(--color-hill-green) 12%, var(--color-white)); color: var(--color-hill-green); }
  .completed .dot { background: var(--color-hill-green); }
  .ongoing { background: var(--color-white); border: 1px solid var(--color-marigold); color: var(--color-deep-marigold); }
  .ongoing .dot { background: var(--color-marigold); }
</style>
