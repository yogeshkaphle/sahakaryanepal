---
import { Picture } from 'astro:assets';
import type { ImageMetadata } from 'astro';
interface Props { src?: ImageMetadata | null; alt: string; caption?: string; ratio?: '16:9' | '4:3'; }
const { src, alt, caption, ratio = '16:9' } = Astro.props;
const ratioValue = ratio === '4:3' ? '4 / 3' : '16 / 9';
---
<figure class="figure" style={`--ratio:${ratioValue}`}>
  {src ? <Picture class="image" src={src} alt={alt} widths={[320, 480, 600, 900, 1180]} sizes="(min-width: 720px) 600px, calc(100vw - 32px)" formats={['avif', 'webp']} loading="lazy" /> : <div class="fallback" role="img" aria-label={alt}>{alt}</div>}
  {caption && <figcaption>{caption}</figcaption>}
</figure>
<style>
  .figure { margin: 0; max-width: 600px; }
  .image, .fallback { aspect-ratio: var(--ratio); border-radius: 0.75rem; display: block; inline-size: 100%; object-fit: cover; }
  .fallback { align-items: center; background: var(--color-stone); color: var(--color-slate); display: flex; font-size: 0.85rem; font-weight: var(--weight-medium); justify-content: center; padding: 1rem; text-align: center; }
  figcaption { color: var(--color-slate); font-size: 0.85rem; font-variant-numeric: tabular-nums; font-weight: var(--weight-medium); line-height: 1.5; margin-top: 0.5rem; }
</style>
