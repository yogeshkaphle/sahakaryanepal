---
// A real field photo with the org's printed caption. Natural aspect ratio
// (no forced crop — these are report photos with people; we do not crop
// faces), capped at 400px display width because the source scans are too
// compressed to hold up larger. astro:assets optimizes at native resolution.
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
interface Props { src: ImageMetadata; alt: string; caption: string; }
const { src, alt, caption } = Astro.props;
---
<figure class="field-photo">
  <Image src={src} alt={alt} loading="lazy" />
  <figcaption>{caption}</figcaption>
</figure>
<style>
  .field-photo { margin: 0; max-width: 400px; }
  .field-photo :global(img) {
    border-radius: 0.75rem;
    display: block;
    height: auto;
    inline-size: 100%;
  }
  figcaption {
    color: var(--color-slate);
    font-size: 0.85rem;
    font-variant-numeric: tabular-nums;
    font-weight: var(--weight-medium);
    line-height: 1.5;
    margin-top: 0.5rem;
  }
</style>
